{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "PyPlyne",
  "scopeName": "source.pyplyne",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#imports" },
    { "include": "#shape-declarations" },
    { "include": "#lambdas" },
    { "include": "#table-verbs" },
    { "include": "#sequence-verbs" },
    { "include": "#constants" },
    { "include": "#placeholders" },
    { "include": "#operators" },
    { "include": "#function-calls" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.pyplyne",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.pyplyne",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.pyplyne",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.pyplyne",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.pyplyne",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.pyplyne",
          "match": "\\b[+-]?(?:\\d+(?:\\.\\d*)?|\\.\\d+)(?:[eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "keyword.control.import.pyplyne",
          "match": "\\b(?:import|from|as)\\b"
        }
      ]
    },
    "shape-declarations": {
      "patterns": [
        {
          "name": "storage.type.pyplyne",
          "match": "\\b(?:df|seq)\\b"
        }
      ]
    },
    "lambdas": {
      "patterns": [
        {
          "name": "keyword.control.lambda.pyplyne",
          "match": "\\bfn\\b|=>"
        }
      ]
    },
    "table-verbs": {
      "patterns": [
        {
          "name": "support.function.table.pyplyne",
          "match": "\\b(?:where|select|mutate|group_by|summarize|arrange|read_csv|write_csv|to_rows|to_table)\\b(?=\\s*\\()"
        }
      ]
    },
    "sequence-verbs": {
      "patterns": [
        {
          "name": "support.function.sequence.pyplyne",
          "match": "\\b(?:map|filter|reduce|set_fields|drop_fields|keep_fields|collect)\\b(?=\\s*\\()"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.pyplyne",
          "match": "\\b(?:True|False|None)\\b"
        },
        {
          "name": "keyword.operator.logical.pyplyne",
          "match": "\\b(?:and|or|not)\\b"
        }
      ]
    },
    "placeholders": {
      "patterns": [
        {
          "name": "variable.parameter.placeholder.pyplyne",
          "match": "\\b_(?:\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipeline.pyplyne",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.comparison.pyplyne",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.pyplyne",
          "match": "//|[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.pyplyne",
          "match": "="
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.pyplyne",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    }
  }
}
